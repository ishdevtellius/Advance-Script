# ─── Kaiya API ───
BASE_URL=https://your-tellius-instance.app.tellius.com
AUTH_TOKEN=Bearer <your-jwt-token>
USER_ID=<your-user-uuid>
TIMEOUT=500

# ─── Google Sheets ───
SPREADSHEET_ID=<your-spreadsheet-id>
SHEET_NAME=Sheet1
GOOGLE_CREDENTIALS_PATH=credentials.json

# ─── OpenAI (for LLM comparison & summary) ───
OPENAI_API_KEY=sk-...

# ─── Business View Mappings (key = exact "Business View" column value in sheet) ───
# Example: Gene_Sales=bv_460689f1-6045-4d79-8ef4-ca9e5a1cebe1

# ─── Execution ───
MAX_WORKERS=5
SEQUENTIAL_EXECUTION=False
